{
    "version": "0.4.81",
    "description": "Cap is an open-source, high-performance screen and video recording application.",
    "homepage": "https://cap.so/",
    "license": "GPL-3.0-only",
    "url": "https://cdn.crabnebula.app/asset/01KMQKWXPT3YAWJS01MSK3PJPW",
    "hash": "bda99766867c09b027ed98a1501521d0cad7055ac3657980afa1eee659e2bd7c",
    "installer": {
        "script": [
            "Expand-7zipArchive \"$dir\\$fname\" \"$dir\" -Removal",
            "Remove-Item \"$dir\\`$PLUGINSDIR\" -Recurse -Force",
            "Remove-Item \"$dir\\uninstall*\" -Force"
        ]
    },
    "shortcuts": [
        [
            "Cap.exe",
            "Cap"
        ]
    ],
    "checkver": {
        "url": "https://api.github.com/repos/CapSoftware/Cap/releases/latest",
        "regex": "(?s)tag_name\"\\s*:\\s*\"cap-v([\\d.]+)\".*?\\[Windows\\]\\((https://cdn\\.crabnebula\\.app/asset/[^\"]+)\\)"
    },
    "autoupdate": {
        "url": "$match2"
    }
}
